# Auto detect text files and perform LF normalization
* text=auto

# Source code files - force LF
*.dart text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.swift text eol=lf
*.kt text eol=lf
*.java text eol=lf

# Config files
*.config text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.env.example text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary files - don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.db binary
*.sqlite binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
