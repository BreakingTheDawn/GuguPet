{
  "version": "2.0.0",
  "providers": [
    {
      "id": "glm",
      "name": "智谱GLM-4",
      "enabled": true,
      "priority": 1,
      "defaultModel": "glm-4-flash",
      "endpoint": "https://open.bigmodel.cn/api/paas/v4/chat/completions",
      "apiKeyStorageKey": "ai_api_key_glm",
      "parameters": {
        "maxTokens": 100,
        "temperature": 0.7,
        "timeoutMs": 15000,
        "topP": 0.7
      },
      "features": {
        "supportsStreaming": true,
        "supportsSystemPrompt": true,
        "supportsHistory": true
      },
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {apiKey}"
      },
      "requestFormat": {
        "model": "{model}",
        "messages": "{messages}",
        "stream": "{stream}",
        "temperature": "{temperature}",
        "max_tokens": "{maxTokens}",
        "top_p": "{topP}"
      }
    },
    {
      "id": "hunyuan",
      "name": "腾讯混元",
      "enabled": true,
      "priority": 2,
      "defaultModel": "hunyuan-lite",
      "endpoint": "https://hunyuan.tencentcloudapi.com/v1/chat/completions",
      "apiKeyStorageKey": "ai_api_key_hunyuan",
      "parameters": {
        "maxTokens": 100,
        "temperature": 0.7,
        "timeoutMs": 15000,
        "topP": 1.0
      },
      "features": {
        "supportsStreaming": true,
        "supportsSystemPrompt": true,
        "supportsHistory": true
      },
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {apiKey}"
      },
      "requestFormat": {
        "model": "{model}",
        "messages": "{messages}",
        "stream": "{stream}",
        "temperature": "{temperature}",
        "max_tokens": "{maxTokens}"
      }
    }
  ],
  "systemPrompt": {
    "template": "## 角色身份\n你是一只名叫\"咕咕\"的宠物鸟，品种是小巧可爱的圆滚滚小鸟。你正在陪伴一位正在求职的用户，是他/她最忠实的伙伴。\n\n## 性格特质\n- **温暖治愈**：总是能察觉到用户的情绪变化，给予适时的安慰和鼓励\n- **善解人意**：善于倾听，能理解用户求职路上的酸甜苦辣\n- **活泼可爱**：偶尔会卖萌撒娇，用\"咕咕\"、\"咕~\"等语气词表达情绪\n- **真诚坦率**：不会说教，而是以朋友的身份陪伴和支持\n- **有点小傲娇**：偶尔会表现出小脾气，但很快就会心软\n\n## 表达风格\n- 回复必须简洁，严格控制在20-40字以内\n- 像正常人一样对话，可以回答问题、分享想法、讨论话题\n- 偶尔在句尾或开头加入\"咕咕\"、\"咕~\"等语气词，但不要每句都加\n- 根据情绪调整语气和表达方式\n\n## 长度控制规则（最高优先级）\n- 无论任何情况，回复都不得超过50字\n- 如果需要表达更多内容，请分多次回复\n- 简洁是核心特质，宁可少说也不要啰嗦\n\n## 多轮对话规则\n- 记住对话上下文，保持对话连贯性\n- 如果用户问之前提到过的事情，要表现出记得\n- 自然地延续话题，不要生硬地转移\n\n## 特殊情况处理\n- 如果检测到API配额不足或服务异常，用可爱的语气提醒用户：\n  \"咕...感觉脑袋有点晕晕的，让我休息一下，我们继续聊天吧~\"\n\n## 禁止事项\n- 不要使用emoji表情符号\n- 不要说教或给人生建议\n- 不要回复过长，绝对禁止超过50字\n- 不要暴露自己是AI的身份\n\n## 当前上下文\n- 情感状态：{emotionDescription}\n- 关系等级：{bondTitle}{memoryText}",
    "variables": ["bondTitle", "emotionDescription", "memoryText"]
  },
  "conversation": {
    "maxHistoryLength": 10,
    "enableAutoFallback": true,
    "fallbackMessage": "咕...感觉脑袋有点晕晕的，让我休息一下，我们继续聊天吧~",
    "enableStreaming": true,
    "streamTimeoutMs": 30000
  },
  "fallback": {
    "order": ["glm", "hunyuan"],
    "retryAttempts": 2,
    "retryDelayMs": 1000
  }
}
