# ===========================================
# 爬虫系统环境变量配置示例
# ===========================================
# 复制此文件为 .env 并填入实际值
# 警告：.env 文件包含敏感信息，请勿提交到版本控制！

# Cookie加密密钥（Fernet对称加密）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COOKIE_ENCRYPTION_KEY=your_encryption_key_here

# 是否启用Cookie加密（True/False）
COOKIE_ENCRYPTION_ENABLED=True

# 代理配置（可选）
# PROXY_ENABLED=False
# PROXY_POOL=

# Webhook告警地址（可选）
# ALERT_WEBHOOK_URL=
